@always_inline
def tree_predict(
    tree: Tree,
    q: UnsafePointer[Int16, origin=MutExternalOrigin],
) -> Tuple[Int, UInt8, UInt8]:
    """Returns (leaf_id, count, safe_a_flag). Walks Modo-A tree.

    q must be a quantized i16 vector (PADDED_DIMS=16).
    """
    var node: Int32 = 0
    while True:
        var ni = Int(node)
        var lc = tree.lefts[ni]
        if lc < 0:
            var leaf = Int(-1 - Int(lc))
            return (leaf, tree.leaf_count[leaf], tree.safe_a[leaf])
        var f = Int(tree.feats[ni])
        var thr = tree.thrs[ni]
        if q[f] <= thr:
            node = lc
        else:
            node = tree.rights[ni]
