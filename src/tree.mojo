"""Scalar decision-tree fast-path (Modo A).

Ported from rival rust tree/generated.rs + leaf_safe.rs.
Nodes: 1023. Leaves: 512.

Heap-backed (libc_malloc) to dodge Mojo b1 InlineArray FFI aliasing
bug that already cost us 1 FN in index_bin scratch buffers.
"""

from std.memory import UnsafePointer
from index_bin import libc_malloc

comptime NODE_COUNT: Int = 1023
comptime LEAF_COUNT: Int = 512

struct Tree(Copyable, Movable):
    var feats: UnsafePointer[Int8, origin=MutExternalOrigin]
    var thrs: UnsafePointer[Int16, origin=MutExternalOrigin]
    var lefts: UnsafePointer[Int32, origin=MutExternalOrigin]
    var rights: UnsafePointer[Int32, origin=MutExternalOrigin]
    var leaf_count: UnsafePointer[UInt8, origin=MutExternalOrigin]
    var safe_a: UnsafePointer[UInt8, origin=MutExternalOrigin]

    def __init__(out self):
        self.feats = libc_malloc(NODE_COUNT).bitcast[Int8]()
        self.thrs = libc_malloc(NODE_COUNT * 2).bitcast[Int16]()
        self.lefts = libc_malloc(NODE_COUNT * 4).bitcast[Int32]()
        self.rights = libc_malloc(NODE_COUNT * 4).bitcast[Int32]()
        self.leaf_count = libc_malloc(LEAF_COUNT)
        self.safe_a = libc_malloc(LEAF_COUNT)
        _tree_fill(self.feats, self.thrs, self.lefts, self.rights, self.leaf_count, self.safe_a)

def _tree_fill(
    feats: UnsafePointer[Int8, origin=MutExternalOrigin],
    thrs: UnsafePointer[Int16, origin=MutExternalOrigin],
    lefts: UnsafePointer[Int32, origin=MutExternalOrigin],
    rights: UnsafePointer[Int32, origin=MutExternalOrigin],
    leaf_count: UnsafePointer[UInt8, origin=MutExternalOrigin],
    safe_a: UnsafePointer[UInt8, origin=MutExternalOrigin],
):
    _fill_nodes_0(feats, thrs, lefts, rights)
    _fill_nodes_1(feats, thrs, lefts, rights)
    _fill_nodes_2(feats, thrs, lefts, rights)
    _fill_nodes_3(feats, thrs, lefts, rights)
    _fill_nodes_4(feats, thrs, lefts, rights)
    _fill_nodes_5(feats, thrs, lefts, rights)
    _fill_nodes_6(feats, thrs, lefts, rights)
    _fill_nodes_7(feats, thrs, lefts, rights)
    _fill_leaves(leaf_count)
    _fill_safe_a(safe_a)

